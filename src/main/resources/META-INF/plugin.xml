<idea-plugin>
  <id>idea.bear.sunday</id>
  <name>BEAR.Sunday</name>
  <version>0.9</version>
  <vendor email="shingo4092@gmail.com">Shingo Kumagai</vendor>
  <resource-bundle>messages.BearSundayBundle</resource-bundle>

  <description><![CDATA[
  <h2>Features</h2>
  <ul>
    <li>BEAR.Resource URI completion</li>
    <li>BEAR.Resource goto from URIs such as <code>app://self/user</code> to <code>src/Resource/App/User.php</code></li>
    <li>BEAR.Resource JSON Schema goto</li>
    <li>Incoming Link/Embed relation gutter for BEAR.Resource methods</li>
    <li>Extract BEAR.Resource parameters to Ray.InputQuery DTO</li>
    <li>Ray.Aop bound interceptor gutter icon and navigation from attributes such as <code>#[Transactional]</code></li>
    <li>Ray.MediaQuery SQL goto</li>
    <li>Ray.QueryModule SQL goto</li>
    <li>Aura.Router goto BEAR.Resource</li>
  </ul>
  <h2>Links</h2>
  <ul>
    <li><a href="https://github.com/bearsunday/idea-php-bearsunday-plugin">GitHub</a></li>
    <li><a href="https://plugins.jetbrains.com/plugin/8030">JetBrains Marketplace</a></li>
  </ul>
  ]]></description>

  <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/build_number_ranges.html for description -->
  <idea-version since-build="251"/>

  <extensions defaultExtensionNs="com.intellij">
    <projectService serviceImplementation="idea.bear.sunday.Settings"/>
    <fileBasedIndex implementation="idea.bear.sunday.index.ResourceIndex"/>
    <fileBasedIndex implementation="idea.bear.sunday.aop.InterceptorBindingIndex"/>
    <fileBasedIndex implementation="idea.bear.sunday.relation.ResourceRelationIndex"/>

    <completion.contributor language="PHP" implementationClass="idea.bear.sunday.resource.UriCompletionContributor"/>
    <completion.contributor language="PHP" order="first" id="BEARResourceAnnotationCompletionContributor" implementationClass="idea.bear.sunday.annotation.AnnotationCompletionContributor"/>
    <codeInsight.lineMarkerProvider language="PHP" implementationClass="idea.bear.sunday.aop.BoundInterceptorLineMarkerProvider"/>
    <codeInsight.lineMarkerProvider language="PHP" implementationClass="idea.bear.sunday.relation.ResourceIncomingRelationLineMarkerProvider"/>

    <gotoDeclarationHandler implementation="idea.bear.sunday.router.RouterGotoDeclarationHandler"/>
    <gotoDeclarationHandler implementation="idea.bear.sunday.annotation.AnnotationOrAttributeGotoDeclarationHandler"/>
    <gotoDeclarationHandler implementation="idea.bear.sunday.resource.ResourceGotoDeclarationHandler"/>
    <gotoDeclarationHandler implementation="idea.bear.sunday.template.EmbedQiqGotoDeclarationHandler"/>

    <psi.referenceContributor language="Twig"
                              implementation="idea.bear.sunday.template.EmbedTemplateReferenceContributor"/>
    <codeInsight.lineMarkerProvider language="Twig"
                                    implementationClass="idea.bear.sunday.template.EmbedTwigLineMarkerProvider"/>
    <!-- Qiq line marker: registered for language="Qiq". The id is contributed by the Qiq
         Templates Support plugin; when that plugin is absent the language stays unresolved and
         this extension is silently disabled, so we keep no compile-time dependency on it.
         Running on the host Qiq PSI (instead of language="PHP" on the injected fragment) is
         what stops the daemon from invoking the provider twice and producing duplicated icons.
         (Goto-declaration for Qiq is the language-agnostic gotoDeclarationHandler above.) -->
    <codeInsight.lineMarkerProvider language="Qiq"
                                    implementationClass="idea.bear.sunday.template.EmbedQiqLineMarkerProvider"/>

    <notificationGroup id="BEAR.Sunday" displayType="BALLOON"/>

  </extensions>

  <depends>com.jetbrains.php</depends>
  <depends>com.jetbrains.twig</depends>
  <depends>com.intellij.modules.platform</depends>
  <depends optional="true" config-file="idea.bear.sunday-annotation.xml">de.espend.idea.php.annotation</depends>

  <actions>
    <action id="idea.bear.sunday.input.ExtractInputDto"
            class="idea.bear.sunday.input.ExtractInputDtoAction"
            text="Extract Input DTO..."
            description="Extract BEAR.Resource method parameters to a Ray.InputQuery DTO">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="RefactoringMenu" anchor="last"/>
    </action>

    <action id="idea.bear.sunday.aop.GoToBoundInterceptor"
            class="idea.bear.sunday.aop.GoToBoundInterceptorAction"
            text="Go to Bound Interceptor"
            description="Navigate from a Ray.Aop attribute to the interceptor bound to it"
            icon="/icons/ray-aop.png">
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
      <add-to-group group-id="GoToMenu" anchor="last"/>
    </action>

    <action id="idea.bear.sunday.template.GoToTemplateOrResource"
            class="idea.bear.sunday.template.GoToTemplateOrResourceAction"
            text="Go to Related Template or Resource"
            description="Navigate between a BEAR.Resource class and its template (Twig/Qiq)"
            icon="/icons/bear.png">
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <add-to-group group-id="EditorPopupMenu" anchor="last"/>
    </action>
  </actions>

</idea-plugin>
